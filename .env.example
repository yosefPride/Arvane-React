# Environment Configuration for Arvane React
# Copy this file to .env.local and fill in your actual values

# WhatsApp Number (without spaces or special characters, include country code)
# Format: VITE_WHATSAPP_NUMBER=+972503331829 or VITE_WHATSAPP_NUMBER=972503331829
VITE_WHATSAPP_NUMBER=+972-50-3331829

# Social Media Links
VITE_FACEBOOK_URL=https://www.facebook.com/arvanecafe
VITE_INSTAGRAM_URL=https://www.instagram.com/arvanecafe
VITE_TWITTER_URL=https://www.twitter.com/arvanecafe
VITE_TIKTOK_URL=https://www.tiktok.com/@arvanecafe

# API Configuration (if you plan to add a backend)
# VITE_API_BASE_URL=https://api.example.com
# VITE_API_KEY=your_api_key_here

# Analytics (optional)
# VITE_ANALYTICS_ID=your_google_analytics_id

# Environment Mode
MODE=development
